# pihole-ha Docker configuration
# Copy to .env and edit before running docker compose up

# --- Required ---

# Comma-separated node IPs in priority order (primary first)
# Append :PORT if Pi-hole runs on a non-standard port (default: 80)
# Example: 192.168.1.10,192.168.1.11:8081
PIHOLE_HA_NODES=192.168.1.10,192.168.1.11

# Gateway/router IP
PIHOLE_HA_GATEWAY=192.168.1.1

# --- Pi-hole ---

# Pi-hole web UI password (also used by FTLCONF_webserver_api_password)
PIHOLE_PASSWORD=

# Timezone
TZ=America/New_York

# --- Optional: VIP (Virtual IP) ---

# Enable floating VIP that follows the active DHCP master
PIHOLE_HA_VIP_ENABLED=false

# VIP address (only used when VIP_ENABLED=true)
PIHOLE_HA_VIP=192.168.1.123

# --- Optional: DHCP ---

# DHCP range — uncomment all three to have pihole-ha manage the DHCP range.
# If left commented, Pi-hole's existing DHCP config is used unchanged.
# PIHOLE_HA_DHCP_START=192.168.1.50
# PIHOLE_HA_DHCP_END=192.168.1.200
# PIHOLE_HA_DHCP_ROUTER=192.168.1.1

# --- Optional: HA behavior ---

# Enable/disable HA failover (default: true)
PIHOLE_HA_ENABLED=true

# --- Optional: Config sync ---

# Enable config sync between nodes (default: true)
PIHOLE_HA_SYNC_ENABLED=true

# Sync individual components (default: all true)
PIHOLE_HA_SYNC_GRAVITY=true
PIHOLE_HA_SYNC_DHCP=true
PIHOLE_HA_SYNC_DNS=true
PIHOLE_HA_SYNC_SETTINGS=true

# Override sync primary (default: first node in PIHOLE_HA_NODES)
# PIHOLE_HA_SYNC_PRIMARY=192.168.1.10

# Sync interval in seconds (default: 900 = 15 minutes)
# PIHOLE_HA_SYNC_INTERVAL=900

# --- Optional: Config generation ---

# Force regenerate config files from env vars on every start (default: false)
# Set to true to always override persisted config with env vars
PIHOLE_HA_FORCE_CONFIG=false
