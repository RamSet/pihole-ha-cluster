            done
            _cfg_nodes+="]"
            printf '{"nodes":%s,"gateway":"%s","pihole_port":%s,"dhcp_ha":"%s"}\n' "$_cfg_nodes" "$_GATEWAY" "$_PIHOLE_PORT" "$_DHCP_HA"
            ;;
        /favicon.ico)
            send_headers "204 No Content" "text/plain"
            ;;
        *)
            # JSON API only; the UI is served by the Pi-hole admin tab (ha.lp).
            send_headers "404 Not Found" "text/plain"; echo "Not Found"
            ;;
    esac
    exit 0
fi

exec socat TCP-LISTEN:"$PORT",fork,reuseaddr EXEC:"$0 --handle",stderr
