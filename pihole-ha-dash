#!/bin/bash
# pihole-ha-dash — Web dashboard for Pi-hole HA cluster
# Serves on port 8887 via socat

PORT=8887
STATUS_FILE="/run/pihole-ha/status.json"

if [[ "${1:-}" == "--handle" ]]; then
    # Load platform abstraction (systemd vs Docker)
    for _p in /usr/local/lib/pihole-ha/pihole-ha-platform ./pihole-ha-platform; do
        [[ -f "$_p" ]] && { . "$_p"; break; }
    done

    # Load node config (with backwards-compatible defaults)
    _NODES_CONF="/etc/pihole-ha/nodes.conf"
    _GATEWAY="" _VIP="" _VIP_ENABLED="" _HA_NODES=""
    [[ -f "$_NODES_CONF" ]] && . "$_NODES_CONF"
    # nodes.conf sets GATEWAY/VIP/HA_NODES (no prefix) — map to prefixed vars
    _GATEWAY="${_GATEWAY:-${GATEWAY:-}}"
    _VIP="${_VIP:-${VIP:-}}"
    _VIP_ENABLED="${_VIP_ENABLED:-${VIP_ENABLED:-}}"
    _HA_NODES="${_HA_NODES:-${HA_NODES:-}}"
    _DHCP_HA="${DHCP_HA:-true}"
    if [[ -z "$_GATEWAY" || -z "$_HA_NODES" ]]; then
        # Auto-detect defaults so dash stays alive for /api/nodes/join
        _LOCAL_IP_DEFAULT="$(ip -o route get 1.0.0.0 2>/dev/null | sed -n 's/.*src \([^ ]*\).*/\1/p')"
        _GATEWAY="${_GATEWAY:-$(ip -o route get 1.0.0.0 2>/dev/null | sed -n 's/.*via \([^ ]*\).*/\1/p')}"
        _HA_NODES="${_HA_NODES:-${_LOCAL_IP_DEFAULT:-127.0.0.1}}"
        echo "WARN: nodes.conf incomplete — using defaults (gateway=$_GATEWAY nodes=$_HA_NODES)" >&2
    fi
    _VIP="${_VIP:-}"
    _VIP_ENABLED="${_VIP_ENABLED:-true}"
    # Parse HA_NODES: supports IP or IP:PORT (default port 80)
    IFS=',' read -ra _RAW_NODES <<< "$_HA_NODES"
    _HA_NODES=()
    declare -A _NODE_PORTS
    for _rn in "${_RAW_NODES[@]}"; do
        if [[ "$_rn" == *:* ]]; then
            _HA_NODES+=("${_rn%%:*}")
            _NODE_PORTS["${_rn%%:*}"]="${_rn##*:}"
        else
            _HA_NODES+=("$_rn")
            _NODE_PORTS["$_rn"]=80
        fi
    done
    _ROLE_NAMES=("PRIMARY" "SECONDARY" "TERTIARY")
    _NODE_COUNT=${#_HA_NODES[@]}
    _ROLES=()
    for (( _ri=0; _ri<_NODE_COUNT; _ri++ )); do
        if (( _ri < ${#_ROLE_NAMES[@]} )); then _ROLES+=("${_ROLE_NAMES[$_ri]}"); else _ROLES+=("NODE$((_ri+1))"); fi
    done

    # is_valid_ip() comes from pihole-ha-platform sourced above.

    _conf_set() {
        # Update KEY=VALUE in nodes.conf (create/append if missing)
        local key="$1" val="$2"
        mkdir -p "$(dirname "$_NODES_CONF")"
        if [[ -f "$_NODES_CONF" ]] && grep -q "^${key}=" "$_NODES_CONF"; then
            sed -i "s|^${key}=.*|${key}=${val}|" "$_NODES_CONF"
        else
            echo "${key}=${val}" >> "$_NODES_CONF"
        fi
    }

    _is_known_node() {
        local ip="$1"
        for _n in "${_HA_NODES[@]}"; do
            [[ "$_n" == "$ip" ]] && return 0
        done
        return 1
    }

    read -r method path _rest
    path="${path%$'\r'}"
    while IFS= read -r hdr; do
        hdr="${hdr%$'\r'}"
        [[ -z "$hdr" ]] && break
    done

    send_headers() {
        printf "HTTP/1.1 %s\r\n" "$1"
        printf "Content-Type: %s\r\n" "$2"
        printf "Cache-Control: no-cache\r\n"
        printf "Connection: close\r\n\r\n"
    }

    # Auth: validate against local Pi-hole's API
    _AUTH_CHECKED="" _AUTH_REQUIRED=""
    # Override local node's port from env var or FTL query
    _LOCAL_IP="$(platform_get_local_ip)"
    if [[ -n "${PIHOLE_WEB_PORT:-}" ]]; then
        _NODE_PORTS["$_LOCAL_IP"]="$PIHOLE_WEB_PORT"
    elif _ftl_port="$(pihole-FTL --config webserver.port 2>/dev/null | grep -o '^[0-9]*')" && [[ -n "$_ftl_port" ]]; then
        _NODE_PORTS["$_LOCAL_IP"]="$_ftl_port"
    fi
    _PIHOLE_PORT="${_NODE_PORTS[$_LOCAL_IP]:-80}"
    _PIHOLE_BASE="http://localhost:${_PIHOLE_PORT}"
    _pihole_has_auth() {
        local resp
        resp="$(curl -s --max-time 2 "${_PIHOLE_BASE}/api/dns/blocking" 2>/dev/null)" || return 1
        echo "$resp" | grep -q '"unauthorized"'
    }
    _validate_sid() {
        local sid="$1"
        [[ -z "$sid" ]] && return 1
        local resp
        resp="$(curl -s --max-time 2 "${_PIHOLE_BASE}/api/dns/blocking?sid=$sid" 2>/dev/null)" || return 1
        ! echo "$resp" | grep -q '"unauthorized"'
    }
    _check_auth() {
        local qs="$1"
        if [[ -z "$_AUTH_CHECKED" ]]; then
            _pihole_has_auth && _AUTH_REQUIRED="true" || _AUTH_REQUIRED="false"
            _AUTH_CHECKED="1"
        fi
        [[ "$_AUTH_REQUIRED" != "true" ]] && return 0
        local sid=""
        IFS='&' read -ra _ap <<< "$qs"
        for _a in "${_ap[@]}"; do [[ "$_a" == sid=* ]] && sid="${_a#sid=}"; done
        _validate_sid "$sid"
    }
    _send_401() {
        send_headers "401 Unauthorized" "application/json"
        echo '{"error":"unauthorized","auth_required":true}'
    }

    # Get SID for propagation to peer nodes
    _get_peer_sid() {
        local ip="$1"
        local _AUTH_CONF="/etc/pihole-ha/auth.conf" _pass="" _key
        _key="PASS_${ip//\./_}"
        if [[ -f "$_AUTH_CONF" ]]; then
            while IFS='=' read -r _k _v; do
                [[ "$_k" == "$_key" ]] && _pass="$_v"
            done < "$_AUTH_CONF"
        fi
        [[ -z "$_pass" ]] && return
        local resp sid
        resp="$(curl -s --max-time 3 -X POST "http://$ip/api/auth" \
            -H "Content-Type: application/json" \
            -d "{\"password\":\"$_pass\"}" 2>/dev/null)" || return
        sid="$(echo "$resp" | grep -o '"sid":"[^"]*"' | cut -d'"' -f4)"
        [[ -n "$sid" && "$sid" != "null" ]] && echo "$sid"
    }
    _urlencode() {
        python3 -c "import sys,urllib.parse; print(urllib.parse.quote(sys.argv[1],safe=''))" "$1" 2>/dev/null \
            || printf '%s' "$1" | sed 's/ /%20/g'
    }
    _propagate_url() {
        local ip="$1" path="$2"
        local sid
        sid="$(_get_peer_sid "$ip")"
        if [[ -n "$sid" ]]; then
            echo "http://$ip:8887${path}&sid=$sid"
        else
            echo "http://$ip:8887${path}"
        fi
    }

    SYNC_MANIFEST="/run/pihole-ha/sync-manifest.json"
    SYNC_PAYLOAD="/run/pihole-ha/sync-payload.tar.gz"
    SYNC_CONF="/etc/pihole-ha/sync.conf"

    case "$path" in
        /api/status)
            send_headers "200 OK" "application/json"
            cat "$STATUS_FILE" 2>/dev/null || echo '{"error":"no status file"}'
            ;;
        /api/auth/check)
            send_headers "200 OK" "application/json"
            if [[ -z "$_AUTH_CHECKED" ]]; then
                _pihole_has_auth && _AUTH_REQUIRED="true" || _AUTH_REQUIRED="false"
                _AUTH_CHECKED="1"
            fi
            printf '{"auth_required":%s}\n' "$_AUTH_REQUIRED"
            ;;
        /api/sync/manifest)
            if [[ -f "$SYNC_MANIFEST" ]]; then
                send_headers "200 OK" "application/json"
                cat "$SYNC_MANIFEST"
            else
                send_headers "404 Not Found" "application/json"
                echo '{"error":"no sync manifest"}'
            fi
            ;;
        /api/sync/generation)
            _gen="$(cat /etc/pihole-ha/sync-generation 2>/dev/null || echo 0)"
            send_headers "200 OK" "application/json"
            printf '{"generation":%s}\n' "$_gen"
            ;;
        /api/sync/payload)
            if [[ -f "$SYNC_PAYLOAD" ]]; then
                printf "HTTP/1.1 200 OK\r\n"
                printf "Content-Type: application/gzip\r\n"
                printf "Content-Length: %d\r\n" "$(stat -c%s "$SYNC_PAYLOAD")"
                printf "Connection: close\r\n\r\n"
                cat "$SYNC_PAYLOAD"
            else
                send_headers "404 Not Found" "application/json"
                echo '{"error":"no sync payload"}'
            fi
            ;;
        /api/sync/config)
            # Read sync config, return as JSON
            SYNC_ENABLED=true SYNC_GRAVITY=true SYNC_DHCP=true SYNC_DNS=true SYNC_SETTINGS=true SYNC_PRIMARY="${_HA_NODES[0]}" SYNC_INTERVAL=15
            [[ -f "$SYNC_CONF" ]] && . "$SYNC_CONF"
            send_headers "200 OK" "application/json"
            printf '{"enabled":%s,"gravity":%s,"dhcp":%s,"dns":%s,"settings":%s,"primary":"%s","interval":%s}\n' \
                "$SYNC_ENABLED" "$SYNC_GRAVITY" "$SYNC_DHCP" "$SYNC_DNS" "$SYNC_SETTINGS" "$SYNC_PRIMARY" "$SYNC_INTERVAL"
            ;;
        /api/sync/toggle/enabled*)
            _qs="${path#*\?}"; if ! _check_auth "$_qs"; then _send_401; exit 0; fi
            mkdir -p /etc/pihole-ha
            SYNC_ENABLED=true SYNC_GRAVITY=true SYNC_DHCP=true SYNC_DNS=true SYNC_SETTINGS=true
            [[ -f "$SYNC_CONF" ]] && . "$SYNC_CONF"
            if [[ "$SYNC_ENABLED" == "true" ]]; then NEW="false"; else NEW="true"; fi
            if [[ -f "$SYNC_CONF" ]]; then
                sed -i "s/^SYNC_ENABLED=.*/SYNC_ENABLED=$NEW/" "$SYNC_CONF"
            else
                printf 'SYNC_ENABLED=%s\nSYNC_GRAVITY=true\nSYNC_DHCP=true\nSYNC_DNS=true\nSYNC_SETTINGS=true\n' "$NEW" > "$SYNC_CONF"
            fi
            send_headers "200 OK" "application/json"
            printf '{"enabled":%s}\n' "$NEW"
            ;;
        /api/sync/toggle/gravity*)
            _qs="${path#*\?}"; if ! _check_auth "$_qs"; then _send_401; exit 0; fi
            mkdir -p /etc/pihole-ha
            SYNC_ENABLED=true SYNC_GRAVITY=true SYNC_DHCP=true SYNC_DNS=true SYNC_SETTINGS=true
            [[ -f "$SYNC_CONF" ]] && . "$SYNC_CONF"
            if [[ "$SYNC_GRAVITY" == "true" ]]; then NEW="false"; else NEW="true"; fi
            if [[ -f "$SYNC_CONF" ]]; then
                sed -i "s/^SYNC_GRAVITY=.*/SYNC_GRAVITY=$NEW/" "$SYNC_CONF"
            else
                printf 'SYNC_ENABLED=true\nSYNC_GRAVITY=%s\nSYNC_DHCP=true\nSYNC_DNS=true\nSYNC_SETTINGS=true\n' "$NEW" > "$SYNC_CONF"
            fi
            send_headers "200 OK" "application/json"
            printf '{"gravity":%s}\n' "$NEW"
            ;;
        /api/sync/toggle/dhcp*)
            _qs="${path#*\?}"; if ! _check_auth "$_qs"; then _send_401; exit 0; fi
            mkdir -p /etc/pihole-ha
            SYNC_ENABLED=true SYNC_GRAVITY=true SYNC_DHCP=true SYNC_DNS=true SYNC_SETTINGS=true
            [[ -f "$SYNC_CONF" ]] && . "$SYNC_CONF"
            if [[ "$SYNC_DHCP" == "true" ]]; then NEW="false"; else NEW="true"; fi
            if [[ -f "$SYNC_CONF" ]]; then
                sed -i "s/^SYNC_DHCP=.*/SYNC_DHCP=$NEW/" "$SYNC_CONF"
            else
                printf 'SYNC_ENABLED=true\nSYNC_GRAVITY=true\nSYNC_DHCP=%s\nSYNC_DNS=true\nSYNC_SETTINGS=true\n' "$NEW" > "$SYNC_CONF"
            fi
            send_headers "200 OK" "application/json"
            printf '{"dhcp":%s}\n' "$NEW"
            ;;
        /api/sync/toggle/dns*)
            _qs="${path#*\?}"; if ! _check_auth "$_qs"; then _send_401; exit 0; fi
            mkdir -p /etc/pihole-ha
            SYNC_ENABLED=true SYNC_GRAVITY=true SYNC_DHCP=true SYNC_DNS=true SYNC_SETTINGS=true
            [[ -f "$SYNC_CONF" ]] && . "$SYNC_CONF"
            if [[ "$SYNC_DNS" == "true" ]]; then NEW="false"; else NEW="true"; fi
            if [[ -f "$SYNC_CONF" ]]; then
                sed -i "s/^SYNC_DNS=.*/SYNC_DNS=$NEW/" "$SYNC_CONF"
            else
                printf 'SYNC_ENABLED=true\nSYNC_GRAVITY=true\nSYNC_DHCP=true\nSYNC_DNS=%s\nSYNC_SETTINGS=true\n' "$NEW" > "$SYNC_CONF"
            fi
            send_headers "200 OK" "application/json"
            printf '{"dns":%s}\n' "$NEW"
            ;;
        /api/sync/toggle/settings*)
            _qs="${path#*\?}"; if ! _check_auth "$_qs"; then _send_401; exit 0; fi
            mkdir -p /etc/pihole-ha
            SYNC_ENABLED=true SYNC_GRAVITY=true SYNC_DHCP=true SYNC_DNS=true SYNC_SETTINGS=true
            [[ -f "$SYNC_CONF" ]] && . "$SYNC_CONF"
            if [[ "$SYNC_SETTINGS" == "true" ]]; then NEW="false"; else NEW="true"; fi
            if [[ -f "$SYNC_CONF" ]]; then
                if grep -q "^SYNC_SETTINGS=" "$SYNC_CONF"; then
                    sed -i "s/^SYNC_SETTINGS=.*/SYNC_SETTINGS=$NEW/" "$SYNC_CONF"
                else
                    echo "SYNC_SETTINGS=$NEW" >> "$SYNC_CONF"
                fi
            else
                printf 'SYNC_ENABLED=true\nSYNC_GRAVITY=true\nSYNC_DHCP=true\nSYNC_DNS=true\nSYNC_SETTINGS=%s\n' "$NEW" > "$SYNC_CONF"
            fi
            send_headers "200 OK" "application/json"
            printf '{"settings":%s}\n' "$NEW"
            ;;
        /api/sync/interval*)
            _qs="${path#*\?}"; if ! _check_auth "$_qs"; then _send_401; exit 0; fi
            _interval="" _propagated=""
            IFS='&' read -ra _ip <<< "$_qs"
            for _p in "${_ip[@]}"; do
                case "$_p" in
                    minutes=*) _interval="${_p#minutes=}" ;;
                    propagated=*) _propagated="${_p#propagated=}" ;;
                esac
            done
            # Validate: must be integer 1-1440
            if [[ "$_interval" =~ ^[0-9]+$ ]] && (( _interval >= 1 && _interval <= 1440 )); then
                mkdir -p /etc/pihole-ha
                if [[ -f "$SYNC_CONF" ]] && grep -q "^SYNC_INTERVAL=" "$SYNC_CONF"; then
                    sed -i "s/^SYNC_INTERVAL=.*/SYNC_INTERVAL=$_interval/" "$SYNC_CONF"
                elif [[ -f "$SYNC_CONF" ]]; then
                    echo "SYNC_INTERVAL=$_interval" >> "$SYNC_CONF"
                else
                    echo "SYNC_INTERVAL=$_interval" > "$SYNC_CONF"
                fi
                # Apply to systemd timers
                platform_sync_set_interval "$_interval"
                # Propagate to peer nodes
                if [[ "$_propagated" != "true" ]]; then
                    LOCAL_IP="$(platform_get_local_ip)"
                    for _node in "${_HA_NODES[@]}"; do
                        [[ "$_node" == "$LOCAL_IP" ]] && continue
                        _peer_url="$(_propagate_url "$_node" "/api/sync/interval?minutes=$_interval&propagated=true")"
                        curl -s --max-time 4 "$_peer_url" &>/dev/null &
                    done
                fi
                send_headers "200 OK" "application/json"
                printf '{"interval":%s}\n' "$_interval"
            else
                send_headers "400 Bad Request" "application/json"
                echo '{"error":"interval must be 1-1440 minutes"}'
            fi
            ;;
        /api/sync/now*)
            _qs="${path#*\?}"; if ! _check_auth "$_qs"; then _send_401; exit 0; fi
            send_headers "200 OK" "application/json"
            LOCAL_IP="$(platform_get_local_ip)"
            SYNC_PRIMARY="${_HA_NODES[0]}"
            [[ -f "$SYNC_CONF" ]] && . "$SYNC_CONF"
            if [[ "$LOCAL_IP" == "$SYNC_PRIMARY" ]]; then
                /usr/local/bin/pihole-ha-sync --force &>/dev/null &
                echo '{"ok":true,"action":"build"}'
            else
                /usr/local/bin/pihole-ha-sync-pull --force &>/dev/null &
                echo '{"ok":true,"action":"pull"}'
            fi
            ;;
        /api/sync/promote*)
            _qs="${path#*\?}"; if ! _check_auth "$_qs"; then _send_401; exit 0; fi
            send_headers "200 OK" "application/json"
            _promote_ip="" _propagated=""
            IFS='&' read -ra _pp <<< "$_qs"
            for _p in "${_pp[@]}"; do
                case "$_p" in
                    ip=*) _promote_ip="${_p#ip=}" ;;
                    propagated=*) _propagated="${_p#propagated=}" ;;
                esac
            done
            # Validate IP format and is a known node
            if ! is_valid_ip "$_promote_ip" || ! _is_known_node "$_promote_ip"; then
                echo '{"error":"invalid node IP"}'
            else
                LOCAL_IP="$(platform_get_local_ip)"
                # Update local sync.conf
                mkdir -p /etc/pihole-ha
                if [[ -f "$SYNC_CONF" ]] && grep -q "^SYNC_PRIMARY=" "$SYNC_CONF"; then
                    sed -i "s/^SYNC_PRIMARY=.*/SYNC_PRIMARY=$_promote_ip/" "$SYNC_CONF"
                else
                    echo "SYNC_PRIMARY=$_promote_ip" >> "$SYNC_CONF"
                fi
                # Manage local timers
                if [[ "$LOCAL_IP" == "$_promote_ip" ]]; then
                    platform_sync_enable
                    platform_sync_pull_disable
                else
                    platform_sync_disable
                    platform_sync_pull_enable
                fi
                # Propagate to other nodes (unless this is a propagated call)
                if [[ "$_propagated" != "1" ]]; then
                    for _node in "${_HA_NODES[@]}"; do
                        [[ "$_node" == "$LOCAL_IP" ]] && continue
                        curl -sf --max-time 5 "$(_propagate_url "$_node" "/api/sync/promote?ip=$_promote_ip&propagated=1")" &>/dev/null &
                    done
                fi
                echo "{\"ok\":true,\"primary\":\"$_promote_ip\"}"
            fi
            ;;
        /api/dhcp/master-config)
            # Read current DHCP master override setting
            _MASTER_CONF="/etc/pihole-ha/master.conf"
            _DHCP_MASTER="auto"
            if [[ -f "$_MASTER_CONF" ]]; then
                while IFS='=' read -r _mk _mv; do
                    [[ "$_mk" == "DHCP_MASTER" ]] && _DHCP_MASTER="$_mv"
                done < "$_MASTER_CONF"
            fi
            send_headers "200 OK" "application/json"
            printf '{"dhcp_master":"%s"}\n' "$_DHCP_MASTER"
            ;;
        /api/dhcp/master*)
            _qs="${path#*\?}"; if ! _check_auth "$_qs"; then _send_401; exit 0; fi
            send_headers "200 OK" "application/json"
            _MASTER_CONF="/etc/pihole-ha/master.conf"
            _master_ip="" _master_propagated=""
            IFS='&' read -ra _mparams <<< "$_qs"
            for _mp in "${_mparams[@]}"; do
                case "$_mp" in
                    ip=*) _master_ip="${_mp#ip=}" ;;
                    propagated=*) _master_propagated="${_mp#propagated=}" ;;
                esac
            done
            # Validate: must be "auto" or a valid known node IP
            if [[ "$_master_ip" != "auto" ]] && { ! is_valid_ip "$_master_ip" || ! _is_known_node "$_master_ip"; }; then
                echo '{"error":"invalid node IP"}'
            else
                mkdir -p /etc/pihole-ha
                echo "DHCP_MASTER=$_master_ip" > "$_MASTER_CONF"
                # Propagate to other nodes (unless this is a propagated call)
                if [[ "$_master_propagated" != "1" ]]; then
                    LOCAL_IP="$(platform_get_local_ip)"
                    for _node in "${_HA_NODES[@]}"; do
                        [[ "$_node" == "$LOCAL_IP" ]] && continue
                        curl -sf --max-time 5 "$(_propagate_url "$_node" "/api/dhcp/master?ip=$_master_ip&propagated=1")" &>/dev/null &
                    done
                fi
                echo "{\"ok\":true,\"dhcp_master\":\"$_master_ip\"}"
            fi
            ;;
        /api/auth/set*)
            _qs="${path#*\?}"; if ! _check_auth "$_qs"; then _send_401; exit 0; fi
            send_headers "200 OK" "application/json"
            _AUTH_CONF="/etc/pihole-ha/auth.conf"
            _auth_ip="" _auth_pass=""
            IFS='&' read -ra _params <<< "$_qs"
            for _p in "${_params[@]}"; do
                case "$_p" in
                    ip=*) _auth_ip="${_p#ip=}" ;;
                    password=*) _auth_pass="${_p#password=}" ;;
                esac
            done
            # URL-decode the password (ha-api.lp percent-encodes it before proxying)
            _auth_pass="$(printf '%b' "${_auth_pass//%/\\x}")"
            # Validate IP format and is one of our known nodes
            if ! is_valid_ip "$_auth_ip" || ! _is_known_node "$_auth_ip"; then
                echo '{"error":"invalid node IP"}'
            elif [[ -z "$_auth_pass" ]]; then
                # Empty password = remove entry
                _key="PASS_${_auth_ip//\./_}"
                mkdir -p /etc/pihole-ha
                touch "$_AUTH_CONF"
                grep -v "^$_key=" "$_AUTH_CONF" > "$_AUTH_CONF.tmp" 2>/dev/null || true
                mv "$_AUTH_CONF.tmp" "$_AUTH_CONF"
                chmod 600 "$_AUTH_CONF" 2>/dev/null || true
                echo "{\"ok\":true,\"ip\":\"$_auth_ip\",\"action\":\"removed\"}"
            else
                _key="PASS_${_auth_ip//\./_}"
                mkdir -p /etc/pihole-ha
                touch "$_AUTH_CONF"
                grep -v "^$_key=" "$_AUTH_CONF" > "$_AUTH_CONF.tmp" 2>/dev/null || true
                echo "$_key=$_auth_pass" >> "$_AUTH_CONF.tmp"
                mv "$_AUTH_CONF.tmp" "$_AUTH_CONF"
                chmod 600 "$_AUTH_CONF" 2>/dev/null || true
                echo "{\"ok\":true,\"ip\":\"$_auth_ip\",\"action\":\"saved\"}"
            fi
            ;;
        /api/ha/config)
            # Read current HA enabled state from nodes.conf
            _HA_ENABLED="true"
            if [[ -f "$_NODES_CONF" ]]; then
                while IFS='=' read -r _hk _hv; do
                    _hv="${_hv#\"}"; _hv="${_hv%\"}"
                    _hv="${_hv#\'}"; _hv="${_hv%\'}"
                    [[ "$_hk" == "HA_ENABLED" ]] && _HA_ENABLED="$_hv"
                done < "$_NODES_CONF"
            fi
            send_headers "200 OK" "application/json"
            printf '{"ha_enabled":%s}\n' "$_HA_ENABLED"
            ;;
        /api/ha/toggle*)
            _qs="${path#*\?}"; if ! _check_auth "$_qs"; then _send_401; exit 0; fi
            send_headers "200 OK" "application/json"
            _ha_propagated=""
            IFS='&' read -ra _hparams <<< "$_qs"
            for _hp in "${_hparams[@]}"; do
                case "$_hp" in
                    propagated=*) _ha_propagated="${_hp#propagated=}" ;;
                esac
            done
            # Read current value
            _HA_ENABLED="true"
            if [[ -f "$_NODES_CONF" ]]; then
                while IFS='=' read -r _hk _hv; do
                    _hv="${_hv#\"}"; _hv="${_hv%\"}"
                    _hv="${_hv#\'}"; _hv="${_hv%\'}"
                    [[ "$_hk" == "HA_ENABLED" ]] && _HA_ENABLED="$_hv"
                done < "$_NODES_CONF"
            fi
            if [[ "$_HA_ENABLED" == "true" ]]; then _NEW_HA="false"; else _NEW_HA="true"; fi
            # Update nodes.conf
            if [[ -f "$_NODES_CONF" ]] && grep -q "^HA_ENABLED=" "$_NODES_CONF"; then
                sed -i "s/^HA_ENABLED=.*/HA_ENABLED=$_NEW_HA/" "$_NODES_CONF"
            else
                echo "HA_ENABLED=$_NEW_HA" >> "$_NODES_CONF"
            fi
            # Propagate to other nodes
            if [[ "$_ha_propagated" != "1" ]]; then
