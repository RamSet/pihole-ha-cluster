#!/bin/bash
# pihole-ha-inject — Install HA page into Pi-hole web UI
# Copies ha.lp + ha.js and patches the sidebar menu.
# Called by installer and by systemd path watcher after Pi-hole updates.

set -euo pipefail

WEBDIR="/var/www/html/admin"
SIDEBAR="$WEBDIR/scripts/lua/sidebar.lp"
SRCDIR="/usr/local/share/pihole-ha"

log() { logger -t pihole-ha-inject "$*"; echo "pihole-ha-inject: $*"; }

# Verify source files exist
if [[ ! -f "$SRCDIR/ha.lp" || ! -f "$SRCDIR/ha.js" || ! -f "$SRCDIR/ha-api.lp" ]]; then
    log "ERROR: Source files not found in $SRCDIR"
    exit 1
fi

# Verify Pi-hole web directory exists
if [[ ! -d "$WEBDIR/scripts/js" ]]; then
    log "ERROR: Pi-hole web directory not found at $WEBDIR"
    exit 1
fi

# 1. Copy page files
cp "$SRCDIR/ha.lp" "$WEBDIR/ha.lp"
cp "$SRCDIR/ha-api.lp" "$WEBDIR/ha-api.lp"
cp "$SRCDIR/ha.js" "$WEBDIR/scripts/js/ha.js"
log "Copied ha.lp, ha-api.lp, and ha.js to Pi-hole web root"

# 2. Patch sidebar if not already done
if [[ ! -f "$SIDEBAR" ]]; then
    log "WARNING: sidebar.lp not found at $SIDEBAR — skipping sidebar patch"
    exit 0
fi

if grep -q 'HA Cluster' "$SIDEBAR"; then
    log "Sidebar already patched — skipping"
    exit 0
fi

# Patch the sidebar with sed/awk — no python3 dependency. python3 is not
# guaranteed on minimal installs and is absent from the Alpine-based Pi-hole
# Docker image, where the old python3-based patch silently failed and the
# "HA Cluster" menu link never appeared.
# 1) add 'ha' to the Tools treeview in_array check so the parent menu opens
sed -i "s/'network'})/'network', 'ha'})/" "$SIDEBAR"
# 2) insert the HA Cluster menu entry before "Update Gravity"
_ha_entry="$(mktemp)"
cat > "$_ha_entry" <<'HAEOF'
                        <!-- HA Cluster -->
                        <li<? if scriptname == 'ha' then ?> class="active"<? end ?>>
                            <a href="<?=webhome?>ha">
                                <i class="fa fa-fw menu-icon fa-server"></i> <span>HA Cluster</span>
                            </a>
                        </li>
HAEOF
awk -v f="$_ha_entry" '
    /<!-- Update Gravity -->/ && !ins { while ((getline l < f) > 0) print l; close(f); ins=1 }
    { print }
' "$SIDEBAR" > "$SIDEBAR.tmp" && mv "$SIDEBAR.tmp" "$SIDEBAR"
rm -f "$_ha_entry"

log "Sidebar patched — HA Cluster menu added under Tools"
